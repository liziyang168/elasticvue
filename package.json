{
  "name": "elasticvue",
  "private": true,
  "version": "1.15.0",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tsc": "tsc --noEmit && vue-tsc",
    "lint": "eslint src tests --fix",
    "lint:style": "stylelint \"src/**/*.{css,scss}\" --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,css,scss}\"",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest watch tests/unit",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:watch": "PWTEST_WATCH=1 playwright test --project=chromium",
    "test:e2e:report": "playwright show-report",
    "ci": "npm run format && npm run lint && npm run lint:style && npm run tsc && npm run build && npm run test:unit && npm run test:e2e:all",
    "tauri:dev": "env GDK_BACKEND=x11 tauri dev",
    "tauri:build": "tauri build",
    "bundle:report": "vite-bundle-visualizer"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@lezer/common": "^1.5.2",
    "@quasar/extras": "^2.0.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "2.3.2",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@tauri-apps/plugin-window-state": "2.4.1",
    "aws4fetch": "^1.0.20",
    "codemirror": "^6.0.2",
    "idb": "^8.0.3",
    "json-bigint": "^1.0.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pretty-bytes": "^7.1.0",
    "quasar": "^2.19.3",
    "strip-json-comments": "^5.0.3",
    "ua-parser-js": "^2.0.10",
    "uuid": "^14.0.0",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.5",
    "vue-resizable": "^2.1.7",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.5.1",
    "@playwright/test": "^1.60.0",
    "@quasar/vite-plugin": "^1.12.0",
    "@tauri-apps/cli": "2.11.2",
    "@types/json-bigint": "^1.0.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.37.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "sass": "^1.100.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.3"
  }
}
